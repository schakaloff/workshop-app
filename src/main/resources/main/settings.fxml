<?import io.github.palexdev.materialfx.dialogs.MFXGenericDialog?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<MFXGenericDialog fx:id="dialogInstance" maxHeight="600.0" maxWidth="800.0" minHeight="600.0" minWidth="800.0" onClose="#closeDialog" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.SettingsController">
   <center>
      <TabPane styleClass="modern-tabs" stylesheets="@../tab.css" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="Techs">
            <content>
              <AnchorPane>
                     <children>
                        <MFXTableView fx:id="techsTable" layoutX="7.0" prefHeight="475.0" prefWidth="750.0" />
                        <MFXButton buttonType="RAISED" depthLevel="LEVEL5" layoutX="647.0" layoutY="449.0" onAction="#saveTechs" prefHeight="25.0" prefWidth="110.0" text="Save" textAlignment="CENTER" />
                        <MFXButton buttonType="RAISED" depthLevel="LEVEL5" layoutX="519.0" layoutY="449.0" onAction="#addNewTech" prefHeight="25.0" prefWidth="110.0" text="Add Tech" textAlignment="CENTER" />
                     </children></AnchorPane>
            </content>
          </Tab>
          <Tab text="Shop Stats">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
            </content>
          </Tab>
            <Tab text="Techs Stats">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
               </content>
            </Tab>
            <Tab text="Settings">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </center>
</MFXGenericDialog>
