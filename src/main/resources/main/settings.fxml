<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXDatePicker?>
<?import io.github.palexdev.materialfx.controls.MFXTableView?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.dialogs.MFXGenericDialog?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<MFXGenericDialog
        fx:id="dialogInstance"
        maxHeight="620.0" maxWidth="820.0"
        minHeight="620.0" minWidth="820.0"
        onClose="#closeDialog"
        prefHeight="620.0" prefWidth="820.0"
        showAlwaysOnTop="false" showClose="true" showMinimize="false"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="Controllers.SettingsController">

    <center>
        <VBox prefHeight="620.0" prefWidth="820.0"
              style="-fx-background-color: white;">
            <children>

                <!-- ─── Top bar ──────────────────────────────────────────── -->
                <HBox alignment="CENTER_LEFT" prefHeight="44" prefWidth="820"
                      spacing="10"
                      style="-fx-background-color: #0097A7; -fx-padding: 0 16 0 16;">
                    <children>
                        <Text text="Shop Settings"
                              style="-fx-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
                    </children>
                </HBox>

                <!-- ─── Tab pane ─────────────────────────────────────────── -->
                <TabPane tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS"
                         prefHeight="576.0" prefWidth="820.0">
                    <tabs>

                        <!-- ═══ TECHS TAB ══════════════════════════════════ -->
                        <Tab text="Technicians">
                            <content>
                                <VBox spacing="0" style="-fx-background-color: white;">
                                    <children>

                                        <!-- Header bar -->
                                        <HBox alignment="CENTER_RIGHT" spacing="10"
                                              style="-fx-background-color: white; -fx-padding: 8 16 8 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                              prefHeight="44">
                                            <children>
                                                <MFXButton onAction="#addNewTech"
                                                           prefHeight="28" prefWidth="100"
                                                           text="Add Tech"
                                                           style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5;" />
                                                <MFXButton onAction="#saveTechs"
                                                           prefHeight="28" prefWidth="80"
                                                           text="Save"
                                                           style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                            </children>
                                        </HBox>

                                        <!-- Table -->
                                        <AnchorPane VBox.vgrow="ALWAYS"
                                                    prefHeight="480"
                                                    style="-fx-background-color: #f5f7fa; -fx-padding: 10 12 12 12;">
                                            <children>
                                                <MFXTableView fx:id="techsTable"
                                                              AnchorPane.topAnchor="0"
                                                              AnchorPane.leftAnchor="0"
                                                              AnchorPane.rightAnchor="0"
                                                              AnchorPane.bottomAnchor="0" />
                                            </children>
                                        </AnchorPane>

                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- ═══ VENDORS TAB ════════════════════════════════ -->
                        <Tab text="Vendors">
                            <content>
                                <VBox spacing="0" style="-fx-background-color: white;">
                                    <children>

                                        <!-- Header bar -->
                                        <HBox alignment="CENTER_RIGHT" spacing="10"
                                              style="-fx-background-color: white; -fx-padding: 8 16 8 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                              prefHeight="44">
                                            <children>
                                                <MFXButton onAction="#addNewVendorFull"
                                                           prefHeight="28" prefWidth="110"
                                                           text="+ New Vendor"
                                                           style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5;" />
                                                <MFXButton onAction="#saveVendors"
                                                           prefHeight="28" prefWidth="80"
                                                           text="Save"
                                                           style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                            </children>
                                        </HBox>

                                        <!-- Table -->
                                        <AnchorPane VBox.vgrow="ALWAYS"
                                                    prefHeight="480"
                                                    style="-fx-background-color: #f5f7fa; -fx-padding: 10 12 12 12;">
                                            <children>
                                                <MFXTableView fx:id="vendorsTable"
                                                              AnchorPane.topAnchor="0"
                                                              AnchorPane.leftAnchor="0"
                                                              AnchorPane.rightAnchor="0"
                                                              AnchorPane.bottomAnchor="0" />
                                            </children>
                                        </AnchorPane>

                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- ═══ SHOP STATS TAB ═════════════════════════════ -->
                        <Tab text="Shop Stats">
                            <content>
                                <VBox spacing="0" style="-fx-background-color: white;">
                                    <children>

                                        <!-- Controls bar -->
                                        <HBox alignment="CENTER_LEFT" spacing="12"
                                              style="-fx-background-color: white; -fx-padding: 12 16 12 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                              prefHeight="60">
                                            <children>
                                                <MFXDatePicker fx:id="statsFromSettingDP"
                                                               floatMode="BORDER" floatingText="From"
                                                               prefHeight="36" prefWidth="130" />
                                                <MFXDatePicker fx:id="statsToSettingDP"
                                                               floatMode="BORDER" floatingText="To"
                                                               prefHeight="36" prefWidth="130" />
                                                <MFXTextField fx:id="shopTotalRepairsTXF"
                                                              floatMode="BORDER" floatingText="Completed WO"
                                                              prefHeight="36" prefWidth="130" />
                                                <MFXTextField fx:id="shopTotalEarnedTXF"
                                                              floatMode="BORDER" floatingText="Total Earned"
                                                              prefHeight="36" prefWidth="130" />
                                                <MFXTextField fx:id="shopTotalPSTTXF"
                                                              floatMode="BORDER" floatingText="PST"
                                                              prefHeight="36" prefWidth="100" />
                                                <MFXTextField fx:id="shopTotalGSTTXF"
                                                              floatMode="BORDER" floatingText="GST"
                                                              prefHeight="36" prefWidth="100" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <MFXButton onAction="#calculateShopStats"
                                                           prefHeight="36" prefWidth="100"
                                                           text="Calculate"
                                                           style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <!-- ═══ TECH STATS TAB ═════════════════════════════ -->
                        <Tab text="Tech Stats">
                            <content>
                                <VBox spacing="0" style="-fx-background-color: white;">
                                    <children>

                                        <!-- Controls bar -->
                                        <HBox alignment="CENTER_LEFT" spacing="12"
                                              style="-fx-background-color: white; -fx-padding: 12 16 12 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                              prefHeight="60">
                                            <children>
                                                <MFXComboBox fx:id="techCombo"
                                                             floatMode="BORDER" floatingText="Tech"
                                                             prefHeight="36" prefWidth="140" />
                                                <MFXDatePicker fx:id="fromDP"
                                                               floatMode="BORDER" floatingText="From"
                                                               prefHeight="36" prefWidth="130" />
                                                <MFXDatePicker fx:id="toDP"
                                                               floatMode="BORDER" floatingText="To"
                                                               prefHeight="36" prefWidth="130" />
                                                <MFXTextField fx:id="totalEarnedTXF"
                                                              floatMode="BORDER" floatingText="Total Earned"
                                                              prefHeight="36" prefWidth="130" />
                                                <MFXTextField fx:id="totalRepairsTXF"
                                                              floatMode="BORDER" floatingText="Repairs Complete"
                                                              prefHeight="36" prefWidth="140" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <MFXButton onAction="#calculate"
                                                           prefHeight="36" prefWidth="100"
                                                           text="Calculate"
                                                           style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                                <MFXButton onAction="#printTechSummary"
                                                           prefHeight="36" prefWidth="130"
                                                           text="Print Summary"
                                                           style="-fx-background-color: #37474F; -fx-text-fill: white; -fx-background-radius: 6;" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </center>
</MFXGenericDialog>
