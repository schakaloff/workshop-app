<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.dialogs.MFXGenericDialog?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<MFXGenericDialog
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="280.0" prefWidth="500.0"
        showAlwaysOnTop="false" showClose="true" showMinimize="false"
        style="-fx-background-color: white;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="Controllers.NewCustomerController">

   <center>
      <VBox prefHeight="280.0" prefWidth="500.0"
            style="-fx-background-color: white;">
         <children>

            <!-- ─── Top bar ──────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" prefHeight="44" prefWidth="500"
                  spacing="10"
                  style="-fx-background-color: #0097A7; -fx-padding: 0 16 0 16;">
               <children>
                  <Text text="New Customer"
                        style="-fx-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
               </children>
            </HBox>

            <!-- ─── Fields row 1 ─────────────────────────────────────── -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 16 16 8 16;">
               <children>
                  <MFXTextField fx:id="firstName"
                                floatMode="BORDER" floatingText="First Name"
                                prefHeight="36" prefWidth="140" />
                  <MFXTextField fx:id="lastName"
                                floatMode="BORDER" floatingText="Last Name"
                                prefHeight="36" prefWidth="140" />
                  <MFXTextField fx:id="phone"
                                floatMode="BORDER" floatingText="Phone"
                                prefHeight="36" prefWidth="140" />
               </children>
            </HBox>

            <!-- ─── Fields row 2 ─────────────────────────────────────── -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 8 16 16 16;">
               <children>
                  <MFXTextField fx:id="address"
                                floatMode="BORDER" floatingText="Address"
                                prefHeight="36" prefWidth="200" />
                  <MFXTextField fx:id="town"
                                floatMode="BORDER" floatingText="Town"
                                prefHeight="36" prefWidth="140" />
                  <MFXTextField fx:id="postalCode"
                                floatMode="BORDER" floatingText="Postal Code"
                                prefHeight="36" prefWidth="100" />
               </children>
            </HBox>

            <!-- ─── Action bar ───────────────────────────────────────── -->
            <HBox alignment="CENTER_RIGHT" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 0 16 16 16;">
               <children>
                  <MFXButton buttonType="RAISED"
                             onAction="#addNewCustomerIntoDB"
                             prefHeight="32" prefWidth="100"
                             text="Save"
                             style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
               </children>
            </HBox>

         </children>
      </VBox>
   </center>
</MFXGenericDialog>
