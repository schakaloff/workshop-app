<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox
      prefWidth="260.0"
      spacing="0"
      style="-fx-background-color: #f5f7fa; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 16, 0, 0, 4);"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.PrintOptionsController">

   <children>

      <!-- ─── Header ─────────────────────────────────────────────── -->
      <HBox alignment="CENTER_LEFT" prefHeight="44"
            style="-fx-background-color: #0097A7; -fx-background-radius: 10 10 0 0; -fx-padding: 0 16 0 16;">
         <children>
            <Label text="🖨  Print Options"
                   style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="woLabel"
                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-size: 11;" />
         </children>
      </HBox>

      <!-- ─── Buttons ────────────────────────────────────────────── -->
      <VBox spacing="8" style="-fx-padding: 16 16 16 16;">
         <children>

            <MFXButton fx:id="btnWorkOrder"
                       onAction="#onWorkOrder"
                       prefHeight="38" prefWidth="228"
                       text="Work Order"
                       style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 7; -fx-border-color: #ddd; -fx-border-radius: 7; -fx-border-width: 1; -fx-font-size: 12;" />

            <MFXButton fx:id="btnEstimate"
                       onAction="#onEstimate"
                       prefHeight="38" prefWidth="228"
                       text="Estimate"
                       style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 7; -fx-border-color: #ddd; -fx-border-radius: 7; -fx-border-width: 1; -fx-font-size: 12;" />

            <MFXButton fx:id="btnRepairComplete"
                       onAction="#onRepairComplete"
                       prefHeight="38" prefWidth="228"
                       text="Repair Complete"
                       style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 7; -fx-border-color: #ddd; -fx-border-radius: 7; -fx-border-width: 1; -fx-font-size: 12;" />

         </children>
      </VBox>

   </children>
</VBox>
