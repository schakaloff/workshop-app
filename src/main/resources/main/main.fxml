<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXDatePicker?>
<?import io.github.palexdev.materialfx.controls.MFXPaginatedTableView?>
<?import io.github.palexdev.materialfx.controls.MFXProgressSpinner?>
<?import io.github.palexdev.materialfx.controls.MFXTableView?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStack" maxHeight="675.0" maxWidth="1000.0" minHeight="675.0" minWidth="1000.0" prefHeight="675.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.ActualWorkshopController">
   <children>
      <BorderPane fx:id="contentPane" prefHeight="675.0" prefWidth="1000.0">

         <!-- ─── Sidebar ─────────────────────────────────────────────────── -->
         <left>
            <VBox fx:id="sidePanel" alignment="TOP_CENTER" prefHeight="675.0" prefWidth="140.0" spacing="6" style="-fx-background-color: #0097A7; -fx-padding: 20 12 16 12;" BorderPane.alignment="CENTER">
               <children>

                  <!-- Avatar -->
                  <Circle fx:id="techAvatar" fill="#00bcd4" radius="35.0" stroke="rgba(255,255,255,0.4)" strokeType="INSIDE" strokeWidth="2.0" />

                  <Label style="-fx-text-fill: white;" text="Welcome!">
                     <font><Font size="12.0" /></font>
                  </Label>

                  <Label fx:id="welcomeTech" style="-fx-text-fill: rgba(255,255,255,0.75);" textAlignment="CENTER" wrapText="true">
                     <font><Font size="11.0" /></font>
                     <VBox.margin><Insets bottom="14" /></VBox.margin>
                  </Label>

                  <!-- Nav buttons — all three have fx:id for active state -->
                  <MFXButton fx:id="btnNavDashboard" buttonType="FLAT" onAction="#showDashboard" prefHeight="36.0" prefWidth="116.0" style="-fx-background-color: rgba(255,255,255,0.20); -fx-text-fill: white; -fx-background-radius: 8;" text="Dashboard" />

                  <MFXButton fx:id="btnNavMyWork" buttonType="FLAT" onAction="#myStats" prefHeight="36.0" prefWidth="116.0" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-background-radius: 8;" text="My Work" />

                  <MFXButton fx:id="btnNavSettings" buttonType="FLAT" onAction="#openSettingsMenu" prefHeight="36.0" prefWidth="116.0" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.75); -fx-background-radius: 8;" text="Shop Settings" />

                  <!-- Spacer pushes sign out to bottom -->
                  <Region VBox.vgrow="ALWAYS" />

                  <MFXButton fx:id="signOutBtn" buttonType="FLAT" onAction="#signOut" prefHeight="36.0" prefWidth="116.0" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.55); -fx-background-radius: 8;" text="Sign Out" />
               </children>
            </VBox>
         </left>

         <!-- ─── Main content ───────────────────────────────────────────── -->
         <center>
            <VBox prefHeight="675.0" prefWidth="860.0" style="-fx-background-color: #f5f7fa;" BorderPane.alignment="CENTER">
               <children>

                  <!-- Top bar with filter buttons + search -->
                  <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="860.0" spacing="8" style="-fx-background-color: white; -fx-padding: 0 16 0 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                     <children>
                        <MFXButton fx:id="btnAllWO" buttonType="FLAT" onAction="#showAllOpenWO" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: #e8f8f9; -fx-text-fill: #0097A7; -fx-background-radius: 6; -fx-border-color: #0097A7; -fx-border-radius: 6; -fx-border-width: 0.5; -fx-font-size: 10;" text="ALL OPEN WO: 0" />
                        <MFXButton fx:id="btnOldNew" buttonType="FLAT" onAction="#showOldNewOver10" prefHeight="28.0" prefWidth="130.0" style="-fx-background-color: white; -fx-text-fill: #666; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5; -fx-font-size: 10;" text="OLD OPENED WO: 0" />
                        <MFXButton fx:id="btnRepairedNotPaid" buttonType="FLAT" onAction="#showRepairedNotPaid" prefHeight="28.0" prefWidth="150.0" style="-fx-background-color: white; -fx-text-fill: #666; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5; -fx-font-size: 10;" text="REPAIRED NOT BILLED: 0" />
                        <MFXButton fx:id="btnShowMyWO" buttonType="FLAT" onAction="#showMyWO" prefHeight="28.0" prefWidth="100.0" style="-fx-background-color: white; -fx-text-fill: #666; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5; -fx-font-size: 10;" text="MY WO: 0" />

                        <Region HBox.hgrow="ALWAYS" />

                        <MFXComboBox fx:id="searchCondition" maxHeight="25.0" maxWidth="100.0" minHeight="25.0" minWidth="100.0" prefHeight="25.0" prefWidth="100.0" />
                        <MFXTextField fx:id="searchTxtField" floatMode="BORDER" floatingText="Quick Search" maxHeight="25.0" maxWidth="100.0" minHeight="25.0" minWidth="100.0" prefHeight="25.0" prefWidth="100.0" />
                        <MFXButton fx:id="newOrderBTN" buttonType="RAISED" onAction="#createNewOrder" prefHeight="25.0" prefWidth="70.0" style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" text="+ New" />
                     </children>
                  </HBox>

                  <!-- Content area — table or my work stacked -->
                  <StackPane VBox.vgrow="ALWAYS">
                     <children>

                        <!-- Dashboard table -->
                        <AnchorPane style="-fx-background-color: #f5f7fa; -fx-padding: 12;">
                           <children>
                              <MFXPaginatedTableView fx:id="table" prefWidth="841.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                           </children>
                        </AnchorPane>

                        <!-- My Work panel -->
                        <AnchorPane fx:id="personalwork" managed="false" prefHeight="621.0" prefWidth="860.0" style="-fx-background-color: #f5f7fa;" visible="false">
                           <children>

                              <!-- Top controls bar -->
                              <HBox alignment="CENTER_LEFT" layoutX="0" layoutY="0" prefHeight="50" prefWidth="860" spacing="10" style="-fx-background-color: white; -fx-padding: 0 16 0 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                                 <children>
                                    <MFXTextField fx:id="techTXF" floatMode="BORDER" floatingText="Tech" prefHeight="28.0" prefWidth="110.0" />
                                    <MFXDatePicker fx:id="fromDPicker" floatMode="BORDER" floatingText="From" prefHeight="36.0" prefWidth="120.0" />
                                    <MFXDatePicker fx:id="toDPicker" floatMode="BORDER" floatingText="To" prefHeight="36.0" prefWidth="120.0" />
                                    <MFXTextField fx:id="tEarnedTXF" floatMode="BORDER" floatingText="Total Earned" prefHeight="36.0" prefWidth="150.0" />
                                    <MFXTextField fx:id="repairsTXF" floatMode="BORDER" floatingText="Repairs Complete" prefHeight="36.0" prefWidth="160.0" />
                                    <MFXButton fx:id="calcBTN" buttonType="RAISED" onAction="#calculateWork" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" text="Calculate" />
                                 </children>
                              </HBox>

                              <!-- Tech work table -->
                              <MFXTableView fx:id="techTable" AnchorPane.bottomAnchor="12" AnchorPane.leftAnchor="12" AnchorPane.rightAnchor="12" AnchorPane.topAnchor="50" />
                           </children>
                        </AnchorPane>

                     </children>
                  </StackPane>

               </children>
            </VBox>
         </center>
      </BorderPane>

      <!-- ─── Loading overlay ────────────────────────────────────────────── -->
      <StackPane fx:id="loadingOverlay" managed="false" style="-fx-background-color: rgba(0,0,0,0.20);" visible="false">
         <MFXProgressSpinner fx:id="loadingSpinner" prefHeight="60" prefWidth="60" />
      </StackPane>

   </children>
</StackPane>
