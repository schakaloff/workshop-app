<?xml version="1.0" encoding="UTF-8"?>
<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXPasswordField?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.LoginController">

   <!-- ─── Left panel ─────────────────────────────── -->
   <left>
      <VBox prefWidth="200" prefHeight="400"
            alignment="CENTER" spacing="10"
            style="-fx-background-color: #0097A7; -fx-padding: 40;">
         <Label text="Teltronics" style="-fx-text-fill: white;">
            <font><Font size="18" /></font>
         </Label>
         <Label text="Service Centre"
                style="-fx-text-fill: rgba(255,255,255,0.6);">
            <font><Font size="13" /></font>
         </Label>
         <Label text="Workshop Management"
                style="-fx-text-fill: rgba(255,255,255,0.3); -fx-padding: 40 0 0 0;">
            <font><Font size="11" /></font>
         </Label>
      </VBox>
   </left>

   <!-- ─── Right panel ────────────────────────────── -->
   <center>
      <AnchorPane prefWidth="400" prefHeight="400"
                  style="-fx-background-color: white;">
         <children>
            <Label text="Welcome back"
                   layoutX="40" layoutY="100">
               <font><Font size="20" /></font>
            </Label>
            <Label text="Sign in to your account"
                   layoutX="40" layoutY="128"
                   style="-fx-text-fill: #888;">
               <font><Font size="13" /></font>
            </Label>

            <Label fx:id="wrongLogin"
                   layoutX="40" layoutY="158"
                   style="-fx-text-fill: #ee0101;">
               <font><Font size="12" /></font>
            </Label>

            <MFXTextField fx:id="usernameField"
                          floatMode="BORDER"
                          floatingText="Username"
                          layoutX="40" layoutY="175"
                          prefWidth="310" />

            <MFXPasswordField fx:id="passwordField"
                              floatMode="BORDER"
                              floatingText="Password"
                              layoutX="40" layoutY="230"
                              prefWidth="310" />

            <MFXButton text="Log In"
                       onAction="#userLogin"
                       buttonType="RAISED"
                       layoutX="40" layoutY="300"
                       prefWidth="310" prefHeight="36"
                       style="-fx-background-color: #0097A7; -fx-text-fill: white;" />

            <Label fx:id="versionLabel"
                   text="v0.0.8"
                   layoutX="330" layoutY="370"
                   style="-fx-text-fill: #999; -fx-font-size: 13; -fx-font-weight: bold;">
               <font><Font size="13.0" /></font>
            </Label>
         </children>
      </AnchorPane>
   </center>

</BorderPane>