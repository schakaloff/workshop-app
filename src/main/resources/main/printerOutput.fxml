<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.dialogs.MFXGenericDialog?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<MFXGenericDialog
        fx:id="dialogRoot"
        maxHeight="-Infinity" maxWidth="-Infinity"
        minHeight="-Infinity" minWidth="-Infinity"
        prefHeight="230.0" prefWidth="300.0"
        showAlwaysOnTop="false" showClose="false" showMinimize="false"
        style="-fx-background-color: #f5f7fa;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="Controllers.PrinterOutputController">

   <center>
      <VBox spacing="0" prefWidth="300.0" prefHeight="230.0"
            style="-fx-background-color: #f5f7fa;">

         <!-- ─── Header bar ─────────────────────────────────────────── -->
         <HBox alignment="CENTER_LEFT" prefHeight="48"
               style="-fx-background-color: #0097A7; -fx-padding: 0 18 0 18;">
            <Label text="🖨  Print"
                   style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;" />
         </HBox>

         <!-- ─── Sub-title ─────────────────────────────────────────── -->
         <HBox alignment="CENTER" prefHeight="36"
               style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <Label text="How would you like to output this document?"
                   style="-fx-text-fill: #666; -fx-font-size: 11;" />
         </HBox>

         <!-- ─── Buttons ───────────────────────────────────────────── -->
         <VBox spacing="10"
               style="-fx-background-color: #f5f7fa; -fx-padding: 18 18 18 18;">

            <MFXButton
                    buttonType="RAISED"
                    onAction="#Printer"
                    prefHeight="36" prefWidth="264"
                    text="🖨   Send to Printer"
                    style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 7; -fx-font-size: 12;" />

            <MFXButton
                    buttonType="RAISED"
                    onAction="#PDF"
                    prefHeight="36" prefWidth="264"
                    text="📄   Save as PDF"
                    style="-fx-background-color: white; -fx-text-fill: #333; -fx-background-radius: 7; -fx-border-color: #ccc; -fx-border-radius: 7; -fx-border-width: 1; -fx-font-size: 12;" />

            <MFXButton
                    buttonType="RAISED"
                    onAction="#Cancel"
                    prefHeight="36" prefWidth="264"
                    text="Cancel"
                    style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-background-radius: 7; -fx-border-color: transparent; -fx-font-size: 11;" />

         </VBox>
      </VBox>
   </center>
</MFXGenericDialog>
