<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXCheckbox?>
<?import io.github.palexdev.materialfx.controls.MFXComboBox?>
<?import io.github.palexdev.materialfx.controls.MFXListView?>
<?import io.github.palexdev.materialfx.controls.MFXTableView?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import io.github.palexdev.materialfx.dialogs.MFXGenericDialog?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<MFXGenericDialog
        maxHeight="-Infinity" maxWidth="-Infinity"
        onClose="#closeDialog"
        prefHeight="490.0" prefWidth="780.0"
        showAlwaysOnTop="false" showClose="true" showMinimize="false"
        style="-fx-background-color: #f5f7fa;"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="Controllers.ViewOrderController">

   <center>
      <VBox prefHeight="490.0" prefWidth="780.0"
            style="-fx-background-color: #f5f7fa;">
         <children>

            <!-- ─── W/O number top bar ───────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" prefHeight="44" prefWidth="780"
                  spacing="10"
                  style="-fx-background-color: #0097A7; -fx-padding: 0 16 0 16;">
               <children>
                  <Text text="Work Order" style="-fx-fill: rgba(255,255,255,0.8); -fx-font-size: 12;" />
                  <MFXTextField fx:id="mainNumberTFX"
                                allowEdit="false"
                                floatMode="BORDER" floatingText="W/O"
                                prefHeight="28" prefWidth="80" />
                  <MFXComboBox fx:id="statusCombo"
                               floatMode="BORDER" floatingText="Status"
                               prefHeight="28" prefWidth="160" />
                  <MFXComboBox fx:id="techIdCombo"
                               floatMode="BORDER" floatingText="Tech"
                               prefHeight="28" prefWidth="120" />
               </children>
            </HBox>

            <!-- ─── Tab pane ────────────────────────────────────────── -->
            <TabPane fx:id="tabPane"
                     VBox.vgrow="ALWAYS"
                     prefHeight="516.0" prefWidth="780.0">
               <tabs>

                  <!-- ═══ MAIN TAB ═══════════════════════════════════ -->
                  <Tab closable="false" text="Main">
                     <content>
                        <VBox spacing="0" style="-fx-background-color: #f5f7fa;">
                           <children>

                              <!-- Device + Warranty row -->
                              <HBox spacing="12" alignment="CENTER_LEFT"
                                    style="-fx-background-color: white; -fx-padding: 12 16 12 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                                 <children>
                                    <MFXTextField fx:id="type"
                                                  floatMode="BORDER" floatingText="Type"
                                                  prefHeight="36" prefWidth="100" />
                                    <MFXTextField fx:id="model"
                                                  floatMode="BORDER" floatingText="Model"
                                                  prefHeight="36" prefWidth="130" />
                                    <MFXTextField fx:id="serialNumber"
                                                  floatMode="BORDER" floatingText="Serial Number"
                                                  prefHeight="36" prefWidth="130" />
                                    <MFXCheckbox fx:id="warrantyCheckBox"
                                                 onAction="#warrantySelected"
                                                 text="Warranty" />
                                    <MFXComboBox fx:id="vendorId"
                                                 floatMode="BORDER" floatingText="Vendor"
                                                 prefHeight="36" prefWidth="130" />
                                    <MFXTextField fx:id="warrantyNumber"
                                                  floatMode="BORDER" floatingText="Warranty Ref#"
                                                  prefHeight="36" prefWidth="130" />
                                 </children>
                              </HBox>

                              <!-- ── Location + PO Number row ──────────────────────────── -->
                              <HBox spacing="12" alignment="CENTER_LEFT"
                                    style="-fx-background-color: #fafbfc; -fx-padding: 10 16 10 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                                 <children>
                                    <MFXTextField fx:id="locationTXF"
                                                  floatMode="BORDER" floatingText="Location  (required for Repair Complete)"
                                                  prefHeight="34" prefWidth="340"
                                                  style="-fx-border-color: #0097A7; -fx-border-radius: 4; -fx-background-radius: 4;" />
                                    <MFXTextField fx:id="poNumber"
                                                  floatMode="BORDER" floatingText="PO Number"
                                                  prefHeight="34" prefWidth="180" />
                                 </children>
                              </HBox>

                              <!-- Customer row -->
                              <HBox spacing="12" alignment="CENTER_LEFT"
                                    style="-fx-background-color: white; -fx-padding: 10 16 10 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                                 <children>
                                    <MFXTextField fx:id="idTFX"
                                                  allowEdit="false"
                                                  floatMode="BORDER" floatingText="ID"
                                                  prefHeight="32" prefWidth="70" />
                                    <MFXTextField fx:id="firstNameTXF"
                                                  allowEdit="false"
                                                  floatMode="BORDER" floatingText="First Name"
                                                  prefHeight="32" prefWidth="110" />
                                    <MFXTextField fx:id="lastNameTXF"
                                                  allowEdit="false"
                                                  floatMode="BORDER" floatingText="Last Name"
                                                  prefHeight="32" prefWidth="110" />
                                    <MFXTextField fx:id="phoneTFX"
                                                  allowEdit="false"
                                                  floatMode="BORDER" floatingText="Phone"
                                                  prefHeight="32" prefWidth="110" />
                                    <MFXTextField fx:id="addressTFX"
                                                  floatMode="BORDER" floatingText="Address"
                                                  prefHeight="32" prefWidth="110" />
                                    <MFXTextField fx:id="townTFX"
                                                  floatMode="BORDER" floatingText="Town"
                                                  prefHeight="32" prefWidth="100" />
                                    <MFXTextField fx:id="zipTFX"
                                                  floatMode="BORDER" floatingText="ZIP"
                                                  prefHeight="32" prefWidth="80" />
                                 </children>
                              </HBox>

                              <!-- Problem description -->
                              <VBox style="-fx-background-color: white; -fx-padding: 12 16 12 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
                                 <children>
                                    <TextArea fx:id="problemDesc"
                                              prefHeight="80" prefWidth="748"
                                              promptText="Problem / Complaint"
                                              wrapText="true"
                                              style="-fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12;" />
                                 </children>
                              </VBox>

                              <!-- Bottom action bar -->
                              <HBox alignment="CENTER_LEFT" spacing="10"
                                    style="-fx-background-color: white; -fx-padding: 10 16 10 16;"
                                    prefHeight="52">
                                 <children>
                                    <Text text="Deposit:" style="-fx-font-size: 12; -fx-fill: #666;" />
                                    <MFXTextField fx:id="depositTXF"
                                                  allowEdit="false"
                                                  floatMode="BORDER" floatingText="Deposit"
                                                  prefHeight="32" prefWidth="100" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <MFXButton buttonType="RAISED"
                                               onAction="#Pay"
                                               prefHeight="32" prefWidth="80"
                                               text="Pay"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                    <MFXButton buttonType="RAISED"
                                               onAction="#printOrder"
                                               prefHeight="32" prefWidth="80"
                                               text="Print"
                                               style="-fx-background-color: #f5f7fa; -fx-text-fill: #333; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5;" />
                                    <MFXButton buttonType="RAISED"
                                               onAction="#printRepaired"
                                               prefHeight="32" prefWidth="110"
                                               text="Print Repaired"
                                               style="-fx-background-color: #f5f7fa; -fx-text-fill: #333; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5;" />
                                    <MFXButton buttonType="RAISED"
                                               onAction="#updateOrder"
                                               prefHeight="32" prefWidth="80"
                                               text="Save"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                 </children>
                              </HBox>

                           </children>
                        </VBox>
                     </content>
                  </Tab>

                  <!-- ═══ LABOUR TAB ═════════════════════════════════ -->
                  <Tab closable="false" text="Labour">
                     <content>
                        <VBox spacing="0" style="-fx-background-color: #f5f7fa;">
                           <children>

                              <!-- Labour header bar -->
                              <HBox alignment="CENTER_LEFT" spacing="12"
                                    style="-fx-background-color: white; -fx-padding: 8 16 8 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                    prefHeight="44">
                                 <children>
                                    <MFXTextField fx:id="customerTFX"
                                                  floatMode="BORDER" floatingText="Customer"
                                                  prefHeight="28" prefWidth="160" />
                                    <MFXTextField fx:id="statusTFX"
                                                  floatMode="BORDER" floatingText="Status"
                                                  prefHeight="28" prefWidth="130" />
                                    <MFXTextField fx:id="numberTFX"
                                                  floatMode="BORDER" floatingText="W/O"
                                                  prefHeight="28" prefWidth="80" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <MFXButton onAction="#onAddStep"
                                               prefHeight="28" prefWidth="100"
                                               text="Add Row"
                                               style="-fx-background-color: #f5f7fa; -fx-text-fill: #333; -fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-radius: 6; -fx-border-width: 0.5;" />
                                    <MFXButton onAction="#repairComplete"
                                               prefHeight="28" prefWidth="130"
                                               text="Repair Complete"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                    <MFXButton onAction="#updateOrder"
                                               prefHeight="28" prefWidth="70"
                                               text="Save"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                 </children>
                              </HBox>

                              <!-- Labour table -->
                              <AnchorPane prefHeight="360" prefWidth="780"
                                          style="-fx-background-color: #f5f7fa; -fx-padding: 10 12 0 12;">
                                 <children>
                                    <MFXTableView fx:id="repairTable"
                                                  AnchorPane.topAnchor="0"
                                                  AnchorPane.leftAnchor="0"
                                                  AnchorPane.rightAnchor="0"
                                                  AnchorPane.bottomAnchor="0" />
                                 </children>
                              </AnchorPane>

                              <!-- Service notes bar -->
                              <VBox style="-fx-background-color: white; -fx-padding: 8 12 8 12; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
                                 <children>
                                    <TextArea fx:id="serviceNotesTXT"
                                              prefHeight="70" prefWidth="756"
                                              promptText="Service notes — visible to all technicians..."
                                              wrapText="true"
                                              style="-fx-font-size: 11; -fx-background-color: #f9f9f9; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-radius: 4;" />
                                 </children>
                              </VBox>

                           </children>
                        </VBox>
                     </content>
                  </Tab>

                  <!-- ═══ PARTS TAB ══════════════════════════════════ -->
                  <Tab closable="false" text="Parts">
                     <content>
                        <VBox spacing="0" style="-fx-background-color: #f5f7fa;">
                           <children>

                              <!-- Parts header bar -->
                              <HBox alignment="CENTER_LEFT" spacing="12"
                                    style="-fx-background-color: white; -fx-padding: 8 16 8 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                    prefHeight="44">
                                 <children>
                                    <MFXTextField fx:id="partsCustomerTFX"
                                                  floatMode="BORDER" floatingText="Customer"
                                                  prefHeight="28" prefWidth="160" />
                                    <MFXTextField fx:id="partsStatusTFX"
                                                  floatMode="BORDER" floatingText="Status"
                                                  prefHeight="28" prefWidth="130" />
                                    <MFXTextField fx:id="partsNumberTFX"
                                                  floatMode="BORDER" floatingText="W/O"
                                                  prefHeight="28" prefWidth="80" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <MFXButton onAction="#addPart"
                                               prefHeight="28" prefWidth="80"
                                               text="Add Part"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                 </children>
                              </HBox>

                              <!-- Parts table -->
                              <AnchorPane prefHeight="420" prefWidth="780"
                                          style="-fx-background-color: #f5f7fa; -fx-padding: 10 12 12 12;">
                                 <children>
                                    <MFXTableView fx:id="partsTable"
                                                  AnchorPane.topAnchor="0"
                                                  AnchorPane.leftAnchor="0"
                                                  AnchorPane.rightAnchor="0"
                                                  AnchorPane.bottomAnchor="0" />
                                 </children>
                              </AnchorPane>

                           </children>
                        </VBox>
                     </content>
                  </Tab>

                  <!-- ═══ FILES TAB ══════════════════════════════════ -->
                  <Tab closable="false" text="Files">
                     <content>
                        <VBox spacing="0" style="-fx-background-color: #f5f7fa;">
                           <children>

                              <!-- Files header bar -->
                              <HBox alignment="CENTER_RIGHT"
                                    style="-fx-background-color: white; -fx-padding: 8 16 8 16; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
                                    prefHeight="44">
                                 <children>
                                    <MFXButton buttonType="RAISED"
                                               onAction="#addFile"
                                               prefHeight="28" prefWidth="90"
                                               text="Add File"
                                               style="-fx-background-color: #0097A7; -fx-text-fill: white; -fx-background-radius: 6;" />
                                 </children>
                              </HBox>

                              <!-- Files list -->
                              <AnchorPane prefHeight="420" prefWidth="780"
                                          style="-fx-background-color: #f5f7fa; -fx-padding: 10 12 12 12;">
                                 <children>
                                    <MFXListView fx:id="filesList"
                                                 AnchorPane.topAnchor="0"
                                                 AnchorPane.leftAnchor="0"
                                                 AnchorPane.rightAnchor="0"
                                                 AnchorPane.bottomAnchor="0" />
                                 </children>
                              </AnchorPane>

                           </children>
                        </VBox>
                     </content>
                  </Tab>

               </tabs>
            </TabPane>
         </children>
      </VBox>
   </center>
</MFXGenericDialog>
